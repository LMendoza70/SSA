# =============================================================================
# Variables de Entorno — Sistema de Gestión de Contenido (Jurisdicción Sanitaria)
# =============================================================================
# Copia este archivo como .env y ajusta los valores para tu ambiente.
# NUNCA versiones .env con secretos reales.
#
# Ambientes:
#   local       → desarrollo individual
#   development → integración temprana
#   staging     → validación previa a producción
#   production  → entorno público institucional
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL: única por ambiente. No reutilizar entre ambientes.
DATABASE_URL="postgresql://ssa_user:ssa_pass_2026@localhost:5432/ssa_db?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Secretos: generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NO reutilizar entre ambientes. Rotar si hay sospecha de exposición.
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API (Backend NestJS) ────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN="http://localhost:5173"
# En production: CORS_ORIGIN="https://dominio-institucional"

# ─── Frontend (URLs públicas) ────────────────────────────────────────────────
# Usadas para CORS, cookies, redirecciones y enlaces públicos.
FRONTEND_URL="http://localhost:5173"
PUBLIC_SITE_URL="http://localhost:5173"
ADMIN_SITE_URL="http://localhost:5173/admin"
API_BASE_URL="http://localhost:3001/api/v1"
BACKEND_URL="http://localhost:3001"

# En production:
# FRONTEND_URL="https://dominio-institucional"
# PUBLIC_SITE_URL="https://dominio-institucional"
# ADMIN_SITE_URL="https://dominio-institucional/admin"
# API_BASE_URL="https://api.dominio-institucional/api/v1"

# ─── Cookies (refresh token) ─────────────────────────────────────────────────
# HttpOnly es fijo en el backend. Secure solo en production (HTTPS).
# SameSite: Lax si mismo dominio, None si dominios separados (requiere Secure).
COOKIE_DOMAIN=""
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"
# En production:
# COOKIE_DOMAIN=".dominio-institucional"
# COOKIE_SECURE="true"
# COOKIE_SAME_SITE="lax"

# ─── Storage (almacenamiento multimedia) ─────────────────────────────────────
# Almacenamiento separado por ambiente. En production debe ser persistente.
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
# MAX_UPLOAD_SIZE=10485760

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_ENV="local"
LOG_LEVEL="debug"
# En production:
# NODE_ENV="production"
# APP_ENV="production"
# LOG_LEVEL="info"
