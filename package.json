{
  "name": "ssa-monorepo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @ssa/api dev",
    "dev:web": "pnpm --filter @ssa/web dev",
    "dev": "pnpm --parallel -r dev",
    "build:api": "pnpm --filter @ssa/api build",
    "build:web": "pnpm --filter @ssa/web build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:generate": "pnpm --filter @ssa/api exec dotenv -e ../../.env -- prisma generate",
    "db:validate": "dotenv -e .env -- prisma validate",
    "setup": "pwsh -NoProfile -File scripts/setup.ps1",
    "admin:create": "pnpm tsx scripts/create-admin.ts",
    "ci:validate": "pnpm lint && pnpm build && pnpm --filter @ssa/api test && pnpm --filter @ssa/web test && pnpm --filter @ssa/api test:integration",
    "backup": "pwsh -NoProfile -File scripts/backup.ps1",
    "restore": "pwsh -NoProfile -File scripts/restore.ps1",
    "prisma:generate": "pnpm --filter @ssa/api exec prisma generate",
    "docker:db": "docker compose up -d",
    "docker:db:stop": "docker compose down"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@scarf/scarf",
      "argon2",
      "prisma"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "kill-port": "^2.0.1",
    "tsx": "^4.23.1",
    "argon2": "^0.41.0",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^8.0.0"
  }
}
